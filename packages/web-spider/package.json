{
	"name": "@danypops/web-spider",
	"version": "0.10.8",
	"files": [
		"dist",
		"package.json"
	],
	"description": "AI-agent-friendly web spider: structured output, RAG-ready chunks, graph-traversable links",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./throttle": {
			"types": "./dist/throttle.d.ts",
			"import": "./dist/throttle.js",
			"default": "./dist/throttle.js"
		},
		"./robots": {
			"types": "./dist/robots.d.ts",
			"import": "./dist/robots.js",
			"default": "./dist/robots.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"test": "vitest --run",
		"check": "tsc --noEmit && tsc -p tsconfig.test.json"
	},
	"dependencies": {
		"@mozilla/readability": "^0.6.0",
		"linkedom": "^0.18.12",
		"minisearch": "^7.2.0",
		"turndown": "^7.2.4"
	},
	"devDependencies": {
		"@types/node": "^22.19.19",
		"@types/turndown": "^5.0.6",
		"typescript": "^5.9.3",
		"vitest": "^3.0.0"
	},
	"optionalDependencies": {
		"playwright-core": "^1.60.0",
		"playwright-extra": "^4.3.6",
		"puppeteer-extra-plugin-stealth": "^2.11.2"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DanyPops/web-spider.git",
		"directory": "packages/web-spider"
	}
}
